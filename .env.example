# ──────────────────────────────────────────────────────────────────
# QL Profitability Dashboard — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────

# HubSpot Private App Token
# Create at: HubSpot > Settings > Integrations > Private Apps
# Required scopes: crm.objects.companies.read, crm.objects.deals.read
HUBSPOT_API_KEY=pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ClickUp Personal API Token
# Get at: ClickUp > Settings > Apps > API Token
CLICKUP_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxx

# Server port (optional, default: 3001)
PORT=3001

# Path to the dashboard HTML template (relative to this file)
# Defaults to the static dashboard at ../profitability-dashboard.html
DASHBOARD_HTML=../profitability-dashboard.html
